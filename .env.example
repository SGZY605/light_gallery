# ==============================
# Light Gallery 环境变量模板
# 使用方式：复制本文件为 .env，然后按实际环境修改取值。
# Windows PowerShell: Copy-Item .env.example .env
# macOS/Linux: cp .env.example .env
# ==============================

# ==============================
# PostgreSQL 数据库配置
# ==============================

# Postgres 容器启动时创建的数据库名。
POSTGRES_DB="light_gallery"

# Postgres 数据库用户名；本地开发保持默认即可，生产环境建议改成独立账号。
POSTGRES_USER="postgres"

# Postgres 数据库密码；生产环境必须改成强密码。
POSTGRES_PASSWORD="postgres"

# Postgres 暴露到宿主机的端口。
# 默认使用 55432，避免和宿主机已有 PostgreSQL 的 5432 端口冲突。
# 你的本地命令 npx prisma db push 会通过这个端口连接数据库。
POSTGRES_PORT="55432"

# 本机开发使用的 Prisma 数据库连接串。
# host 使用 127.0.0.1，避免部分 Windows/Docker 环境下 localhost 优先解析到 IPv6 ::1 导致 Prisma 无法连接。
# 端口要和 POSTGRES_PORT 一致，用户名、密码、库名要和上面三项一致。
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:55432/light_gallery?schema=public"

# Docker app 容器内部使用的 Prisma 数据库连接串。
# host 必须使用 docker-compose 服务名 postgres，不要改成 localhost。
DOCKER_DATABASE_URL="postgresql://postgres:postgres@postgres:5432/light_gallery?schema=public"

# ==============================
# 应用运行配置
# ==============================

# Docker app 容器的 Node 运行环境。生产镜像使用 production；本机 npm run dev 不依赖这个值。
NODE_ENV="production"

# 本机开发端口固定为 3001。npm run dev 会读取这个值。
DEV_PORT="3001"

# Docker app 宿主访问端口固定为 3000。
# 容器内部也固定监听 3000；开发时不要把 Docker 改到 3001。
APP_PORT="3000"

# Docker app 容器内监听地址。容器运行必须使用 0.0.0.0，不能只监听 localhost。
APP_HOSTNAME="0.0.0.0"

# 登录会话签名密钥。生产环境必须替换成足够长的随机字符串，泄露后需要立即更换。
SESSION_SECRET="replace-with-a-long-random-secret"

# 登录 cookie 是否强制 Secure。
# 留空时会按请求协议自动判断：HTTP 本地 Docker 不加 Secure，HTTPS 或 x-forwarded-proto=https 会加 Secure。
# 如果应用只通过 HTTPS 对外访问，可设置为 true；如果明确使用 HTTP 部署，可设置为 false。
SESSION_COOKIE_SECURE=""

# Playwright 冒烟测试访问的站点地址。默认指向 Docker app；如需测开发服务可临时改为 http://127.0.0.1:3001。
PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"

# ==============================
# 数据初始化配置
# ==============================

# 受保护管理员账号 admin@example.com 的初始密码。
# npm run db:seed 会创建该账号；如果此变量存在，也会把该账号密码更新为这里的值。
SEED_ADMIN_PASSWORD="admin"

# Docker app 容器启动时是否自动执行 npm run db:seed。
# 本机开发按手动命令 npm run db:seed 执行；Docker 一键启动时可保持 true。
RUN_DB_SEED="true"

# Docker app 容器等待数据库 schema 初始化的最大重试次数。
DB_INIT_MAX_ATTEMPTS="30"

# Docker app 容器每次数据库初始化重试之间等待的秒数。
DB_INIT_RETRY_DELAY_SECONDS="2"

# ==============================
# 阿里云 OSS 配置
# ==============================

# OSS 区域。可以写 cn-shanghai，也可以写完整主机区域格式。
OSS_REGION="cn-shanghai"

# OSS Bucket 名称。
OSS_BUCKET="light-gallery"

# OSS AccessKey ID。需要有上传、读取目标 Bucket 的权限。
OSS_ACCESS_KEY_ID="your-access-key-id"

# OSS AccessKey Secret。生产环境不要提交到 git，也不要泄露给前端。
OSS_ACCESS_KEY_SECRET="your-access-key-secret"

# 服务端生成图片访问地址时使用的公开基础地址。
# 如果使用 CDN，这里填写 CDN 域名；否则可填写 https://<bucket>.oss-<region>.aliyuncs.com。
OSS_PUBLIC_BASE_URL="https://light-gallery.oss-cn-shanghai.aliyuncs.com"

# 服务端签名直传时使用的 OSS 上传基础地址。
# 通常和 OSS_PUBLIC_BASE_URL 相同；使用 CDN 只做访问加速时，这里仍应填写 OSS Bucket 域名。
OSS_UPLOAD_BASE_URL="https://light-gallery.oss-cn-shanghai.aliyuncs.com"

# 客户端组件生成图片地址时使用的公开基础地址。
# 通常和 OSS_PUBLIC_BASE_URL 保持一致。
NEXT_PUBLIC_OSS_PUBLIC_BASE_URL="https://light-gallery.oss-cn-shanghai.aliyuncs.com"

# 单个文件允许上传的最大字节数。默认 26214400 = 25 MiB。
OSS_MAX_UPLOAD_BYTES="26214400"

# OSS 上传策略有效期，单位秒。默认 300 秒。
OSS_POLICY_EXPIRES_SECONDS="300"

# 允许上传的 MIME 类型前缀。默认 image/ 表示只允许图片。
OSS_ALLOWED_MIME_PREFIX="image/"

# 上传到 OSS 时写入 object key 的目录前缀。
OSS_UPLOAD_PREFIX="uploads"
